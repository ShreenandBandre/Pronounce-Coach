generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
model Attempt {
  id           String   @id @default(uuid())
  sessionId    String
  transcript   String
  overallScore Int
  flaggedWords Json
  summary      String
  createdAt    DateTime @default(now())
 
  @@index([sessionId])
}
